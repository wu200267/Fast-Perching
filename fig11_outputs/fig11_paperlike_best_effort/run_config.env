scene_surface_axis=0.0,1.0,0.0
scene_surface_theta=-1.5708
scene_zt_values=2.0,1.5,1.0

fix_terminal_state=false
v_plus=0.3
thrust_min=5.0
thrust_max=17.0
omega_max=3.0
vt_multistart_enable=true
vt_multistart_vt2_seeds=0.0,0.1,-0.1,0.4,-0.4
vt_multistart_eps_strict=0.001
vt_multistart_eps_relaxed=0.01

