{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Workspace (Release)",
      "type": "shell",
      "command": "/bin/bash",
      "args": [
        "-lc",
        "source /opt/ros/noetic/setup.bash && catkin_make -DCMAKE_BUILD_TYPE=Release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
